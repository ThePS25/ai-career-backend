NODE_ENV=development
PORT=5000

# MongoDB (MONGO_URI or MONGODB_URI)
MONGO_URI=mongodb+srv://<user>:<password>@<cluster>.mongodb.net/ai-career-prep?retryWrites=true&w=majority

JWT_SECRET=your-super-secret-jwt-key-change-in-production
JWT_EXPIRES_IN=7d

# Frontend URL for CORS (required in production)
CLIENT_URL=http://localhost:5173

# Hugging Face — create at https://huggingface.co/settings/tokens
# Use a fine-grained token with "Make calls to Inference Providers" (or legacy "Read")
HF_API_KEY=hf_your_token_here
HF_CHAT_URL=https://router.huggingface.co/v1/chat/completions
HF_MODEL=google/gemma-4-31B-it
HF_TIMEOUT_MS=90000
HF_MAX_RETRIES=5
HF_COOLDOWN_MS=3000
HF_429_RETRY_BASE_MS=3000
# HF_SKIP_STARTUP_CHECK=true

# Gemini (optional)
GEMINI_API_KEY=your_gemini_api_key_here
GEMINI_PRIMARY_MODEL=gemini-3.5-flash
GEMINI_FALLBACK_MODEL=gemini-pro
GEMINI_TIMEOUT_MS=90000
GEMINI_MAX_RETRIES=3

# Default provider when both are available: huggingface | gemini
AI_PROVIDER=huggingface

# JSearch API via RapidAPI (https://rapidapi.com/letscrape-6bRBa3QguO5/api/jsearch)
RAPIDAPI_KEY=your_rapidapi_key_here
RAPIDAPI_HOST=jsearch.p.rapidapi.com
JSEARCH_LOCATION=India

# Google OAuth (https://console.cloud.google.com/apis/credentials)
GOOGLE_CLIENT_ID=your_google_client_id.apps.googleusercontent.com
